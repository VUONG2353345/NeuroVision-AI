        <string notr="true">/* Trạng thái bình thường (bị tắt) */
QPushButton {
    background-color: transparent; 
    color: #6b7280; 
    border: none; 
    border-radius: 8px;
    padding: 10px;
    font-weight: bold;
    font-size: 14px;
}

/* Trạng thái khi lướt chuột qua */
QPushButton:hover {
    background-color: #e5e7eb; 
}

/* CHỈ LÊN MÀU XANH ĐẬM KHI ĐƯỢC BẬT (CHECKED) */
QPushButton:checked {
    background-color: #1a56db; 
    color: white;
}</string>
